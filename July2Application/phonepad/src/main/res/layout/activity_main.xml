<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@android:color/white"
    tools:context=".MainActivity">

    <!-- 상단: 번호 표시 및 연락처 추가 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/phone_display"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="22sp"
            android:padding="12dp"
            android:gravity="center_vertical|start" />

        <Button
            android:id="@+id/btn_add_contact"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/round_button"
            android:text="연락처 추가"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 키패드 -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="*"
        android:shrinkColumns="*">

        <TableRow android:layout_marginBottom="8dp">
            <Button
                android:id="@+id/btn1"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button"
                android:text="1"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn2"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button"
                android:text="2"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn3"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button"
                android:text="3"
                android:textSize="24sp" />
        </TableRow>

        <TableRow android:layout_marginBottom="8dp">
            <Button
                android:id="@+id/btn4"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button"
                android:text="4"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn5"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button"
                android:text="5"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn6"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button"
                android:text="6"
                android:textSize="24sp" />
        </TableRow>

        <TableRow android:layout_marginBottom="8dp">
            <Button
                android:id="@+id/btn7"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button"
                android:text="7"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn8"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button"
                android:text="8"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn9"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button"
                android:text="9"
                android:textSize="24sp" />
        </TableRow>

        <TableRow>
            <Button
                android:id="@+id/btn_video"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button"
                android:text="영상"
                android:textSize="18sp"
                android:contentDescription="영상통화" />

            <Button
                android:id="@+id/btn0"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button"
                android:text="0"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/round_button_delete"
                android:contentDescription="숫자삭제"
                android:text="삭제"
                android:textSize="18sp" />
        </TableRow>

    </TableLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btn_call"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:background="@drawable/round_button_call"
            android:text="통화"
            android:textColor="@android:color/white"
            android:textSize="18sp" />

    </LinearLayout>

</LinearLayout>